<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ title }}</title>
  <meta name="description" content="{{ description }}" />
  <meta name="robots" content="{{ robots | default('index, follow') }}" />
  <link rel="canonical" href="https://www.stegeas.com{{ canonical }}" />

  <meta property="og:title" content="{{ title }}" />
  <meta property="og:description" content="{{ description }}" />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://www.stegeas.com{{ canonical }}" />
  <meta property="og:image" content="https://www.stegeas.com/assets/toulouse.webp" />
  <meta property="og:locale" content="fr_FR" />
  <meta property="og:site_name" content="Stégéas" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/main.css?v=8" />

  {% block head %}{% endblock %}
</head>
<body>

  <!-- NAV -->
  <nav class="nav" aria-label="Navigation principale">
    <div class="nav__inner">
      <a class="nav__logo" href="/" aria-label="Stégéas — Accueil">
        <img src="/assets/logo_stegeas.png" alt="Logo Stégéas" width="120" height="40" />
      </a>
      <ul class="nav__links" role="list">
        <li><a href="/">Accueil</a></li>
        <li><a href="/cabinet.html">Le Cabinet</a></li>
        <li><a href="/professionnels.html">Professionnels</a></li>
        <li><a href="/particuliers.html">Particuliers</a></li>
        <li><a href="https://travel-protect.neat.eu" target="_blank" rel="noopener">Visa Schengen</a></li>
      </ul>
      <div class="nav__right">
        <a href="/contact.html" class="nav__cta">Nous contacter</a>
        <button class="nav__burger" aria-label="Ouvrir le menu" aria-expanded="false">
          <span></span><span></span><span></span>
        </button>
      </div>
    </div>
  </nav>

  <div class="nav__mobile" role="navigation" aria-label="Menu mobile">
    <a href="/">Accueil</a>
    <a href="/cabinet.html">Le Cabinet</a>
    <a href="/professionnels.html">Professionnels</a>
    <a href="/particuliers.html">Particuliers</a>
    <a href="https://travel-protect.neat.eu" target="_blank" rel="noopener">Visa Schengen</a>
    <a href="/contact.html" class="nav__cta">Nous contacter</a>
  </div>

  {% block content %}{% endblock %}

  <!-- FOOTER -->
  <footer class="footer" role="contentinfo">
    <div class="container">
      <div class="footer__inner">
        <a href="/" class="footer__logo" aria-label="Stégéas — Accueil">
          <img src="/assets/logo_stegeas.png" alt="Stégéas" height="72" />
        </a>
        <nav class="footer__links" aria-label="Liens de bas de page">
          <a href="/cabinet.html">Le Cabinet</a>
          <a href="/mentions-legales.html">Mentions légales</a>
          <a href="/contact.html">Contact</a>
          <span style="color:rgba(255,255,255,0.2);font-size:0.75rem;">ORIAS 07006002</span>
        </nav>
        <div class="footer__socials" aria-label="Réseaux sociaux">
          <a href="https://www.linkedin.com/company/stegeas" target="_blank" rel="noopener" aria-label="LinkedIn">
            <img src="https://cdn.prod.website-files.com/63441ed9f7d7aac6edd9ad1c/6347cbd7945dd659de0b8bc9_linked%20in%20blanc.webp" alt="LinkedIn" />
          </a>
          <a href="https://www.instagram.com/stegeas" target="_blank" rel="noopener" aria-label="Instagram">
            <img src="https://cdn.prod.website-files.com/63441ed9f7d7aac6edd9ad1c/6347cbd7832a10a41497cb2f_instagram%20blanc.webp" alt="Instagram" />
          </a>
          <a href="https://www.facebook.com/stegeas" target="_blank" rel="noopener" aria-label="Facebook">
            <img src="https://cdn.prod.website-files.com/63441ed9f7d7aac6edd9ad1c/6347cbdeb01dc81270f340e2_facebook%20blanc.webp" alt="Facebook" />
          </a>
        </div>
      </div>
      <div style="border-top:1px solid rgba(255,255,255,0.06); margin-top:1.5rem; padding-top:1.5rem; display:flex; flex-direction:column; align-items:center; gap:0.4rem; text-align:center;">
        <p style="font-size:0.75rem; color:rgba(255,255,255,0.35);">2 Rue du Pré Fermé, 31200 Toulouse</p>
        <p style="font-size:0.75rem; color:rgba(255,255,255,0.35);"><a href="tel:+33562883704" style="color:rgba(255,255,255,0.35);">05 62 88 37 04</a></p>
        <p style="font-size:0.75rem; color:rgba(255,255,255,0.35);"><a href="mailto:contact@stegeas.fr" style="color:rgba(255,255,255,0.35);">contact@stegeas.fr</a></p>
      </div>
      <p class="footer__copy">© 2026 Stégéas — Cabinet de courtage en assurances à Toulouse. Tous droits réservés.</p>
    </div>
  </footer>

  <script src="/js/main.js"></script>
  <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
  <script>
    if (window.netlifyIdentity) {
      window.netlifyIdentity.on("init", user => {
        if (!user) {
          window.netlifyIdentity.on("login", () => { document.location.href = "/admin/"; });
        }
      });
    }
  </script>
  {% block scripts %}{% endblock %}
</body>
</html>
