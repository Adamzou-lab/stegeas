        </div>
      </div>
    </div>
  </section>

  <!-- CONTACT STRIP -->
  <section class="contact-strip" id="contact" aria-labelledby="contact-title">
    <div class="container">
      <div style="text-align:center;">
        <h2 id="contact-title" style="color:var(--white); font-size:1rem; font-weight:600;">
          {{ contact_strip | safe }}
        </h2>
      </div>
    </div>
  </section>

{% endblock %}
