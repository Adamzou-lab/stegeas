          <img src="https://cdn.prod.website-files.com/63441ed9f7d7aac6edd9ad1c/69a83f2b0b55eb72b61b0a30_Swiss_Life_logo_SwissLife.png" alt="Swiss Life" />
          <img src="https://cdn.prod.website-files.com/63441ed9f7d7aac6edd9ad1c/6346d12654ebc4e896e5b269_April.webp" alt="April" />
          <img src="https://cdn.prod.website-files.com/63441ed9f7d7aac6edd9ad1c/6346d124088cadce7834ee97_Solly%20Azar.webp" alt="Solly Azar" />
          <img src="https://cdn.prod.website-files.com/63441ed9f7d7aac6edd9ad1c/6346d00c73dd1d5a5a22ea2f_Albingia.webp" alt="Albingia" />
          <img src="https://cdn.prod.website-files.com/63441ed9f7d7aac6edd9ad1c/69a83ee1e91234a9309fdf3d_logo-assurmax.png" alt="Assurmax" />
          <img src="https://cdn.prod.website-files.com/63441ed9f7d7aac6edd9ad1c/69a83e7190801c5120d19519_groupama-nouvelle-identite-viquelle-logo-696x268.png" alt="Groupama" />
          <img src="https://cdn.prod.website-files.com/63441ed9f7d7aac6edd9ad1c/6346d00de1a8d6285b7bcda7_AXA.svg.webp" alt="" aria-hidden="true" />
          <img src="https://cdn.prod.website-files.com/63441ed9f7d7aac6edd9ad1c/6346d00fb2cf4786860d4fc8_Allianz.webp" alt="" aria-hidden="true" />
          <img src="https://cdn.prod.website-files.com/63441ed9f7d7aac6edd9ad1c/6346d010e1a8d6285b7bcddb_generali.webp" alt="" aria-hidden="true" />
          <img src="https://cdn.prod.website-files.com/63441ed9f7d7aac6edd9ad1c/6346d12354ebc43d0be5b260_MMA.webp" alt="" aria-hidden="true" />
          <img src="https://cdn.prod.website-files.com/63441ed9f7d7aac6edd9ad1c/6346d00db2cf47d8710d4fb4_Alptis.webp" alt="" aria-hidden="true" />
          <img src="https://cdn.prod.website-files.com/63441ed9f7d7aac6edd9ad1c/69a83f2b0b55eb72b61b0a30_Swiss_Life_logo_SwissLife.png" alt="" aria-hidden="true" />
          <img src="https://cdn.prod.website-files.com/63441ed9f7d7aac6edd9ad1c/6346d12654ebc4e896e5b269_April.webp" alt="" aria-hidden="true" />
          <img src="https://cdn.prod.website-files.com/63441ed9f7d7aac6edd9ad1c/6346d124088cadce7834ee97_Solly%20Azar.webp" alt="" aria-hidden="true" />
          <img src="https://cdn.prod.website-files.com/63441ed9f7d7aac6edd9ad1c/6346d00c73dd1d5a5a22ea2f_Albingia.webp" alt="" aria-hidden="true" />
